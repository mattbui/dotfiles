set shell zsh
set icons
set drawbox true
set period 1
set scrolloff 5
set info size:time
set hidden true
set previewer ~/.config/lf/preview.sh
set preview true

map <c-q> quit
map <c-c> quit
map <esc> quit
map ~ cd ~
map <enter> open
map . set hidden!
map J :toggle; down
map K :toggle; up

cmd yank-abs-path &{{
    paths=$(
        first=1
        printf '%s\n' "$fx" | while IFS= read -r file; do
            target=$file
            if [ -d "$file" ]; then
                target="$target/"
            fi

            if [ "$first" -eq 1 ]; then
                first=0
            else
                printf '\n'
            fi

            printf '%s' "$target"
        done
    )

    if command -v pbcopy >/dev/null 2>&1; then
        printf '%s' "$paths" | pbcopy
    elif command -v xclip >/dev/null 2>&1; then
        printf '%s' "$paths" | xclip -selection clipboard
    else
        lf -remote "send $id echoerr 'yank-path: pbcopy or xclip not found'"
        exit 1
    fi

    lf -remote "send $id echo 'yanked path'"
}}

cmd yank-md-link &{{
    links=$(
        first=1
        printf '%s\n' "$fx" | while IFS= read -r file; do
            label=${file##*/}
            target=$file
            if [ -d "$file" ]; then
                target="$target/"
            fi
            label=$(printf '%s' "$label" | sed 's/]/\\]/g')

            if [ "$first" -eq 1 ]; then
                first=0
            else
                printf '\n'
            fi

            printf '[%s](%s)' "$label" "$target"
        done
    )

    if command -v pbcopy >/dev/null 2>&1; then
        printf '%s' "$links" | pbcopy
    elif command -v xclip >/dev/null 2>&1; then
        printf '%s' "$links" | xclip -selection clipboard
    else
        lf -remote "send $id echoerr 'yank-link: pbcopy or xclip not found'"
        exit 1
    fi

    lf -remote "send $id echo 'yanked link'"
}}

map y
map yy copy
map yp yank-md-link
map yP yank-abs-path

cmd osOpen &open "$f"
map o osOpen

cmd qlpreview &{{
    pid=$(qlmanage -p "$f" >/dev/null 2>&1 & echo $!)

    osascript <<APPLESCRIPT >/dev/null 2>&1
delay 0.1
tell application "System Events"
    set matchingProcesses to every process whose unix id is $pid
    if (count of matchingProcesses) > 0 then
        set p to item 1 of matchingProcesses
        set frontmost of p to true
        if (count of windows of p) > 0 then
            perform action "AXRaise" of window 1 of p
        end if
    end if
end tell
APPLESCRIPT
}}
map <space> qlpreview

cmd extract %atool -x "$f"
map x extract

cmd tmuxNewWindow &{{
    if [ -z "${TMUX:-}" ]; then
        lf -remote "send $id echoerr 'tmux-window: not inside tmux'"
        exit 1
    fi

    target_dir=$PWD
    [ -d "$f" ] && target_dir=$f

    if tmux new-window -c "$target_dir"; then
        [ "${LF_TMUX_POPUP:-}" = "1" ] && lf -remote "send $id quit"
    else
        lf -remote "send $id echoerr 'failed to create tmux window'"
        exit 1
    fi
}}

cmd tmuxNewSession &{{
    if [ -z "${TMUX:-}" ]; then
        lf -remote "send $id echoerr 'tmux-session: not inside tmux'"
        exit 1
    fi

    target_dir=$PWD
    [ -d "$f" ] && target_dir=$f

    base=${target_dir##*/}
    [ -n "$base" ] || base=root
    base=$(printf '%s' "$base" | tr ':' '_')

    session_name=$base
    index=1
    while tmux has-session -t "=$session_name" 2>/dev/null; do
        session_name="${base}(${index})"
        index=$((index + 1))
    done

    if tmux new-session -d -s "$session_name" -c "$target_dir" && tmux switch-client -t "=$session_name"; then
        [ "${LF_TMUX_POPUP:-}" = "1" ] && lf -remote "send $id quit"
    else
        lf -remote "send $id echoerr 'failed to create tmux session: $session_name'"
        exit 1
    fi
}}

# Override lf's default `t` tag-toggle mapping so `t` can prefix tmux actions.
map t
map tt tmuxNewWindow
map tn tmuxNewSession

cmd trash ${{
    clear; tput cup $(($(tput lines)/3)); tput bold
    set -f
    space=$' '
    tok_space=$'<SPACE>'

    printf "%s\n\t" "$fx"
    printf "Move to trash?[y/N] "
    read ans
    [ $ans = "y" ] && for file in $(echo $fx | sed s/$space/$tok_space/g | tr '\n' ' ')
    do
        trash "$(echo $file | sed s/$tok_space/$space/g )"
    done
}}
map T trash

# purge the unclean
cmd remove ${{
    clear; tput cup $(($(tput lines)/3)); tput bold
    set -f
    space=$' '
    tok_space=$'<SPACE>'

    printf "%s\n\t" "$fx"
    printf "Delete?[y/N] "
    read ans
    [ $ans = "y" ] && for file in $(echo $fx | sed s/$space/$tok_space/g | tr '\n' ' ')
    do
        rm -rf "$(echo $file | sed s/$tok_space/$space/g )"
    done
}}
map D remove

cmd addDir %{{
    printf "Directory name or path? "
    read ans
    mkdir -p $ans
}}
map A addDir

cmd addFile %{{
    printf "Filename? "
    read ans
    touch $ans
}}
map a addFile

cmd openWithEditor ${{
    quote() {
        printf '%s' "$1" | sed "s/'/'\\\\\\\\''/g; 1s/^/'/; \$s/\$/'/"
    }

    if [ -n "${LF_NVIM_FLOATERM:-}" ]; then
        floaterm "$f"
        exit
    fi

    if [ -z "${TMUX:-}" ]; then
        ${EDITOR:-vi} "$f"
        exit
    fi

    target=$(quote "$f")
    shell=$(quote "${SHELL:-/bin/sh}")
    if tmux new-window -c "$PWD" "${EDITOR:-vi} $target; exec $shell -l"; then
        [ "${LF_TMUX_POPUP:-}" = "1" ] && lf -remote "send $id quit"
    else
        lf -remote "send $id echoerr 'failed to open editor in tmux window'"
        exit 1
    fi
}}

map e openWithEditor
