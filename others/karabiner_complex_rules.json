    {
      "description": "Ctrl + Delete → Option + Delete",
      "manipulators": [
        {
          "description": "Ctrl + Delete → Option + Delete",
          "from": {
            "key_code": "delete_or_backspace",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "delete_or_backspace",
              "modifiers": ["option"],
              "repeat": true
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Hold Command + H to Hide otherwise trigger F13",
      "manipulators": [
        {
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": ["command"],
              "optional": ["caps_lock"]
            }
          },
          "to_if_alone": [
            {
              "key_code": "f13"
            }
          ],
          "to_if_held_down": [
            {
              "key_code": "h",
              "modifiers": ["left_command"],
              "repeat": false
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Hold Command + M to Minimize",
      "manipulators": [
        {
          "from": {
            "key_code": "m",
            "modifiers": {
              "mandatory": ["command"],
              "optional": ["caps_lock"]
            }
          },
          "to_if_held_down": [
            {
              "key_code": "m",
              "modifiers": ["left_command"],
              "repeat": false
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Hold Command + Q to Quit",
      "manipulators": [
        {
          "from": {
            "key_code": "q",
            "modifiers": {
              "mandatory": ["command"],
              "optional": ["caps_lock"]
            }
          },
          "to_if_held_down": [
            {
              "key_code": "q",
              "modifiers": ["left_command"],
              "repeat": false
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Ctrl + Left/Right → Option + Left/Right",
      "manipulators": [
        {
          "description": "Ctrl + Left Arrow → Option + Left Arrow",
          "from": {
            "key_code": "left_arrow",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": ["option"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "Ctrl + Right Arrow → Option + Right Arrow",
          "from": {
            "key_code": "right_arrow",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_arrow",
              "modifiers": ["option"]
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Double Shift → Hyper Key hold (2 s)",
      "manipulators": [
        {
          "description": "Tap Right Shift while holding Left Shift → Hyper Key hold",
          "from": {
            "key_code": "right_shift",
            "modifiers": {
              "mandatory": ["left_shift"]
            }
          },
          "to_if_alone": [
            {
              "sticky_modifier": {
                "left_command": "on"
              }
            },
            {
              "sticky_modifier": {
                "left_option": "on"
              }
            },
            {
              "sticky_modifier": {
                "left_control": "on"
              }
            },
            {
              "set_notification_message": {
                "id": "double_shift_hyper",
                "text": "✦ Hyper Key\n\nB · Arc\nC · ChatGPT\nD · Discord\nF · Find My\nM · Messages\nS · Slack\nT · Alacritty\n⇧T · Ghostty"
              }
            }
          ],
          "to_delayed_action": {
            "to_if_invoked": [
              {
                "sticky_modifier": {
                  "left_command": "off"
                }
              },
              {
                "sticky_modifier": {
                  "left_option": "off"
                }
              },
              {
                "sticky_modifier": {
                  "left_control": "off"
                }
              },
              {
                "set_notification_message": {
                  "id": "double_shift_hyper",
                  "text": ""
                }
              }
            ],
            "to_if_canceled": [
              {
                "set_notification_message": {
                  "id": "double_shift_hyper",
                  "text": ""
                }
              }
            ]
          },
          "parameters": {
            "basic.to_delayed_action_delay_milliseconds": 2000
          },
          "type": "basic"
        },
        {
          "description": "Hyper Key + Esc → cancel",
          "from": {
            "key_code": "escape",
            "modifiers": {
              "mandatory": ["command", "option", "control"]
            }
          },
          "to": [
            {
              "sticky_modifier": {
                "left_command": "off"
              }
            },
            {
              "sticky_modifier": {
                "left_option": "off"
              }
            },
            {
              "sticky_modifier": {
                "left_control": "off"
              }
            },
            {
              "set_notification_message": {
                "id": "double_shift_hyper",
                "text": ""
              }
            }
          ],
          "type": "basic"
        }
      ]
    },
