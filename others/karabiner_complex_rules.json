{
  "rules": [
    {
      "description": "Alacritty/Ghostty: tmux session switch Ctrl hold behavior",
      "manipulators": [
        {
          "description": "Ctrl+Shift+Tab → Ctrl+Shift+Tab and arm tmux session switch finalize",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^org\\.alacritty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ],
          "from": {
            "key_code": "tab",
            "modifiers": {
              "mandatory": ["control", "shift"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "tmux_session_switching",
                "value": 1
              }
            },
            {
              "key_code": "tab",
              "modifiers": ["control", "shift"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "Ctrl+Tab → Ctrl+Tab and arm tmux session switch finalize",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^org\\.alacritty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ],
          "from": {
            "key_code": "tab",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "tmux_session_switching",
                "value": 1
              }
            },
            {
              "key_code": "tab",
              "modifiers": ["control"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "Left Ctrl release sends F18 only after Ctrl-Tab session switching",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^org\\.alacritty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ],
          "from": {
            "key_code": "left_control",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_control",
              "lazy": true
            }
          ],
          "to_after_key_up": [
            {
              "key_code": "f18",
              "conditions": [
                {
                  "type": "variable_if",
                  "name": "tmux_session_switching",
                  "value": 1
                }
              ]
            },
            {
              "set_variable": {
                "name": "tmux_session_switching",
                "value": 0
              }
            }
          ],
          "type": "basic"
        },
        {
          "description": "Right Ctrl release sends F18 only after Ctrl-Tab session switching",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^org\\.alacritty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ],
          "from": {
            "key_code": "right_control",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_control",
              "lazy": true
            }
          ],
          "to_after_key_up": [
            {
              "key_code": "f18",
              "conditions": [
                {
                  "type": "variable_if",
                  "name": "tmux_session_switching",
                  "value": 1
                }
              ]
            },
            {
              "set_variable": {
                "name": "tmux_session_switching",
                "value": 0
              }
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Tab → Option (mod-tap)",
      "manipulators": [
        {
          "description": "Tab → Option (mod-tap)",
          "from": {
            "key_code": "tab",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_option",
              "lazy": true
            }
          ],
          "to_if_alone": [
            {
              "key_code": "tab"
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Esc/Backtick shortcuts",
      "manipulators": [
        {
          "description": "Command + Shift + Esc → Triple Backtick + Shift + Enter",
          "from": {
            "key_code": "escape",
            "modifiers": {
              "mandatory": ["command", "shift"]
            }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde"
            },
            {
              "key_code": "grave_accent_and_tilde"
            },
            {
              "key_code": "grave_accent_and_tilde"
            },
            {
              "key_code": "return_or_enter",
              "modifiers": ["shift"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "Shift + Esc → Tilde",
          "from": {
            "key_code": "escape",
            "modifiers": {
              "mandatory": ["shift"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde",
              "modifiers": ["shift"]
            }
          ],
          "type": "basic"
        },
        {
          "description": "Command + Backtick → Triple Backtick",
