            "key_code": "grave_accent_and_tilde",
            "modifiers": {
              "mandatory": ["command"]
            }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde"
            },
            {
              "key_code": "grave_accent_and_tilde"
            },
            {
              "key_code": "grave_accent_and_tilde"
            }
          ],
          "type": "basic"
        },
        {
          "description": "Command + Esc → Triple Backtick",
          "from": {
            "key_code": "escape",
            "modifiers": {
              "mandatory": ["command"]
            }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde"
            },
            {
              "key_code": "grave_accent_and_tilde"
            },
            {
              "key_code": "grave_accent_and_tilde"
            }
          ],
          "type": "basic"
        },
        {
          "description": "Command + Shift + Backtick → Triple Backtick + Shift + Enter",
          "from": {
            "key_code": "grave_accent_and_tilde",
            "modifiers": {
              "mandatory": ["command", "shift"]
            }
          },
          "to": [
            {
              "key_code": "grave_accent_and_tilde"
            },
            {
              "key_code": "grave_accent_and_tilde"
            },
            {
              "key_code": "grave_accent_and_tilde"
            },
            {
              "key_code": "return_or_enter",
              "modifiers": ["shift"]
            }
          ],
          "type": "basic"
        }
      ]
