{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^(startup|resume)$",
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.codex/hooks/codex_tmux_title.sh",
            "statusMessage": "Setting tmux title"
          }
        ]
      }
    ]
  }
}
