#!/usr/bin/env sh

# yabai config - SIP-safe defaults

add_and_apply_rule() {
  label="$1"
  shift

  yabai -m rule --remove "$label" >/dev/null 2>&1 || :
  yabai -m rule --add label="$label" "$@"
  yabai -m rule --apply "$label"
}

add_signal() {
  label="$1"
  shift

  yabai -m signal --remove "$label" >/dev/null 2>&1 || :
  yabai -m signal --add label="$label" "$@"
}

# Apply manage=off rules before setting layout defaults so ignored windows are
# excluded before yabai starts reconfiguring spaces on reload.
# shellcheck source=/dev/null
. "$HOME/.config/yabai/scripts/ignore-list.sh"
list_ignore | while IFS= read -r app; do
  [ -n "$app" ] || continue
  label=$(ignore_rule_label "$app")
  regex=$(ignore_app_regex "$app")
  add_and_apply_rule "$label" app="$regex" manage=off
done

# Core layout defaults. scripts/apply-layout.sh will apply display-aware overrides.
yabai -m config \
  layout                       bsp \
  split_type                   auto \
  split_ratio                  0.45 \
  auto_balance                 off \
  window_placement             second_child \
  window_insertion_point       focused \
  window_zoom_persist          on \
  mouse_follows_focus          off \
  focus_follows_mouse          off \
  window_shadow                on \
  window_opacity               off \
  window_animation_duration    0.0 \
  skip_window_focus_animation  off \
  top_padding                  6 \
  bottom_padding               8 \
  left_padding                 8 \
  right_padding                8 \
  window_gap                   10 \
  mouse_modifier               alt \
  mouse_action1                move \
  mouse_action2                resize \
  mouse_drop_action            stack

# Label displays and spaces by physical left-to-right display order.
$HOME/.config/yabai/scripts/label-spaces-displays.sh

# Default space rules.
add_and_apply_rule "space-Alacritty" app="^Alacritty$" space=space-2
add_and_apply_rule "space-Codex" app="^Codex$" space=space-2
add_and_apply_rule "space-Slack" app="^Slack$" space=space-1
add_and_apply_rule "space-Discord" app="^Discord$" space=space-1
add_and_apply_rule "space-Spark" app="^Spark$" space=space-1

# Re-apply layout when window/application visibility changes.
yabai_apply_layout="$HOME/.config/yabai/scripts/apply-layout.sh"
add_signal "layout-window-created" event=window_created action="$yabai_apply_layout"
add_signal "layout-window-destroyed" event=window_destroyed action="$yabai_apply_layout"
add_signal "layout-application-hidden" event=application_hidden action="$yabai_apply_layout"
add_signal "layout-application-visible" event=application_visible action="$yabai_apply_layout"
add_signal "layout-window-minimized" event=window_minimized action="$yabai_apply_layout"
add_signal "layout-window-deminimized" event=window_deminimized action="$yabai_apply_layout"

# Restore focus when close/minimize/hide leaves macOS frontmost but no visible
# yabai window is focused. Cmd-W for Notes/Messages/Finder is handled in skhdrc;
# these signals cover mouse/menu closes and apps outside that skhd Cmd-W list.
yabai_refocus="$HOME/.config/yabai/scripts/refocus.sh"
add_signal "refocus-window-destroyed-active" event=window_destroyed active=yes action="$yabai_refocus"
add_signal "refocus-window-minimized-active" event=window_minimized active=yes action="$yabai_refocus"
add_signal "refocus-application-hidden-active" event=application_hidden active=yes action="$yabai_refocus"

# Re-apply layout when focus moves to another space/display.
yabai_skip_focus="$HOME/.config/yabai/scripts/skip-focus.sh"
add_signal "layout-space-changed" event=space_changed action="$yabai_skip_focus; $yabai_apply_layout"
add_signal "layout-display-changed" event=display_changed action="$yabai_skip_focus; $yabai_apply_layout"

# Re-label spaces when the space set changes.
yabai_label_spaces="$HOME/.config/yabai/scripts/label-spaces-displays.sh"
add_signal "label-space-created" event=space_created action="$yabai_label_spaces"
add_signal "label-space-destroyed" event=space_destroyed action="$yabai_label_spaces"

# Re-label displays/spaces when display topology changes.
add_signal "label-display-added" event=display_added action="$yabai_label_spaces"
add_signal "label-display-removed" event=display_removed action="$yabai_label_spaces"
add_signal "label-display-moved" event=display_moved action="$yabai_label_spaces"
add_signal "label-display-resized" event=display_resized action="$yabai_label_spaces; $yabai_apply_layout"

$HOME/.config/yabai/scripts/apply-layout.sh

printf '%s\n' "yabai config loaded"
