#!/usr/bin/env sh

# yabai config - SIP-safe defaults

add_and_apply_rule() {
  label="$1"
  shift

  yabai -m rule --remove "$label" >/dev/null 2>&1 || :
  yabai -m rule --add label="$label" "$@"
  yabai -m rule --apply "$label"
}

# Apply manage=off rules before setting layout defaults so ignored windows are
# excluded before yabai starts reconfiguring spaces on reload.
# shellcheck source=/dev/null
. "$HOME/.config/yabai/scripts/ignore-list.sh"
list_ignore | while IFS= read -r app; do
  [ -n "$app" ] || continue
  label=$(ignore_rule_label "$app")
  regex=$(ignore_app_regex "$app")
  add_and_apply_rule "$label" app="$regex" manage=off
done

# Core layout defaults. scripts/apply-layout.sh will apply display-aware overrides.
yabai -m config \
  layout                       bsp \
  split_type                   auto \
  split_ratio                  0.45 \
  auto_balance                 off \
  window_placement             second_child \
  window_insertion_point       focused \
  window_zoom_persist          on \
  mouse_follows_focus          off \
  focus_follows_mouse          off \
  window_shadow                on \
  window_opacity               off \
  window_animation_duration    0.0 \
  skip_window_focus_animation  off \
  top_padding                  6 \
  bottom_padding               8 \
  left_padding                 8 \
  right_padding                8 \
  window_gap                   10 \
  mouse_modifier               alt \
  mouse_action1                move \
  mouse_action2                resize \
  mouse_drop_action            stack

# Label displays and spaces by physical left-to-right display order.
$HOME/.config/yabai/scripts/label-spaces-displays.sh

# Default space rules.
add_and_apply_rule "space-Alacritty" app="^Alacritty$" space=space-2
add_and_apply_rule "space-Codex" app="^Codex$" space=space-2
add_and_apply_rule "space-Slack" app="^Slack$" space=space-1
add_and_apply_rule "space-Discord" app="^Discord$" space=space-1
add_and_apply_rule "space-Spark" app="^Spark$" space=space-1

# Re-apply layout when window/application visibility changes.
yabai -m signal --add event=window_created action="$HOME/.config/yabai/scripts/apply-layout.sh"
yabai -m signal --add event=window_destroyed action="$HOME/.config/yabai/scripts/apply-layout.sh"
yabai -m signal --add event=application_hidden action="$HOME/.config/yabai/scripts/apply-layout.sh"
yabai -m signal --add event=application_visible action="$HOME/.config/yabai/scripts/apply-layout.sh"
yabai -m signal --add event=window_minimized action="$HOME/.config/yabai/scripts/apply-layout.sh"
yabai -m signal --add event=window_deminimized action="$HOME/.config/yabai/scripts/apply-layout.sh"

# Re-apply layout when focus moves to another space/display.
yabai -m signal --add event=space_changed action="$HOME/.config/yabai/scripts/skip-focus.sh; $HOME/.config/yabai/scripts/apply-layout.sh"
yabai -m signal --add event=display_changed action="$HOME/.config/yabai/scripts/skip-focus.sh; $HOME/.config/yabai/scripts/apply-layout.sh"

# Re-label spaces when the space set changes.
yabai -m signal --add event=space_created action="$HOME/.config/yabai/scripts/label-spaces-displays.sh"
yabai -m signal --add event=space_destroyed action="$HOME/.config/yabai/scripts/label-spaces-displays.sh"

# Re-label displays/spaces when display topology changes.
yabai -m signal --add event=display_added action="$HOME/.config/yabai/scripts/label-spaces-displays.sh"
yabai -m signal --add event=display_removed action="$HOME/.config/yabai/scripts/label-spaces-displays.sh"
yabai -m signal --add event=display_moved action="$HOME/.config/yabai/scripts/label-spaces-displays.sh"
yabai -m signal --add event=display_resized action="$HOME/.config/yabai/scripts/label-spaces-displays.sh; $HOME/.config/yabai/scripts/apply-layout.sh"

$HOME/.config/yabai/scripts/apply-layout.sh

printf '%s\n' "yabai config loaded"
