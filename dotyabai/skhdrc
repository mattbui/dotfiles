# skhd hotkeys for yabai

# Focus windows.
alt - h : yabai -m window --focus west || yabai -m space --focus prev || yabai -m space --focus last
alt - l : yabai -m window --focus east || yabai -m space --focus next || yabai -m space --focus first
alt - j : yabai -m window --focus south || yabai -m window --focus stack.next || yabai -m window --focus stack.first
alt - k : yabai -m window --focus north || yabai -m window --focus stack.prev || yabai -m window --focus stack.last

# Move/reinsert focused window. Warp un-stacks a single focused window instead of moving the whole stack pane.
cmd + alt - h : if yabai -m window --space prev; then yabai -m space --focus prev; else yabai -m window --space last; yabai -m space --focus last; fi
cmd + alt - l : if yabai -m window --space next; then yabai -m space --focus next; else yabai -m window --space first; yabai -m space --focus first; fi

# Resize focused window/pane.
alt - 0x1B : $HOME/.config/yabai/scripts/resize.sh shrink
alt - 0x18 : $HOME/.config/yabai/scripts/resize.sh grow

# Toggle float modes.
alt - c : $HOME/.config/yabai/scripts/toggle-float.sh center
alt - return : $HOME/.config/yabai/scripts/toggle-float.sh fullscreen

# Switch focused/left-stack window into main, or reset/re-apply display-aware layout.
alt - m : $HOME/.config/yabai/scripts/switch-main.sh
alt - 0 : $HOME/.config/yabai/scripts/apply-layout.sh

# Focus displays by physical left-to-right order. Labels are assigned by scripts/label-displays.sh.
alt - 1 : yabai -m display --focus display-1
alt - 2 : yabai -m display --focus display-2
alt - 3 : yabai -m display --focus display-3

# Focus spaces.
ctrl - 1 : $HOME/.config/yabai/scripts/focus-space.sh 1
ctrl - 2 : $HOME/.config/yabai/scripts/focus-space.sh 2
ctrl - 3 : $HOME/.config/yabai/scripts/focus-space.sh 3
ctrl - 4 : $HOME/.config/yabai/scripts/focus-space.sh 4
ctrl - 5 : $HOME/.config/yabai/scripts/focus-space.sh 5
ctrl - 6 : $HOME/.config/yabai/scripts/focus-space.sh 6
ctrl - 7 : $HOME/.config/yabai/scripts/focus-space.sh 7
ctrl - 8 : $HOME/.config/yabai/scripts/focus-space.sh 8
ctrl - 9 : $HOME/.config/yabai/scripts/focus-space.sh 9

# Move focused window to spaces and follow it.
ctrl + cmd - 1 : $HOME/.config/yabai/scripts/move-space.sh 1
ctrl + cmd - 2 : $HOME/.config/yabai/scripts/move-space.sh 2
ctrl + cmd - 3 : $HOME/.config/yabai/scripts/move-space.sh 3
ctrl + cmd - 4 : $HOME/.config/yabai/scripts/move-space.sh 4
ctrl + cmd - 5 : $HOME/.config/yabai/scripts/move-space.sh 5
ctrl + cmd - 6 : $HOME/.config/yabai/scripts/move-space.sh 6
ctrl + cmd - 7 : $HOME/.config/yabai/scripts/move-space.sh 7
ctrl + cmd - 8 : $HOME/.config/yabai/scripts/move-space.sh 8
ctrl + cmd - 9 : $HOME/.config/yabai/scripts/move-space.sh 9

# Move focused window to displays by physical left-to-right order and follow it.
alt + cmd - 1 : yabai -m window --display display-1; yabai -m display --focus display-1
alt + cmd - 2 : yabai -m window --display display-2; yabai -m display --focus display-2
alt + cmd - 3 : yabai -m window --display display-3; yabai -m display --focus display-3
