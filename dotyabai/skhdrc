# skhd hotkeys for yabai

# Focus windows.
# skip-focus mark enables the next yabai space/display-change hook to redirect
# focus away from skip apps like Antinote; it is short-lived and consumed once.
alt - h : yabai -m window --focus west || ($HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus prev) || ($HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus last)
alt - l : yabai -m window --focus east || ($HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus next) || ($HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus first)
alt - j : yabai -m window --focus south || yabai -m window --focus stack.next || yabai -m window --focus stack.first
alt - k : yabai -m window --focus north || yabai -m window --focus stack.prev || yabai -m window --focus stack.last
escape [
  "antinote" : yabai -m window --focus recent
  * ~
]

# Yabai controls.
cmd + alt + shift - r : $HOME/.config/yabai/scripts/restart-yabai.sh
cmd + alt - r : $HOME/.config/yabai/scripts/label-spaces-displays.sh --notify
cmd + alt - 0x2F : app=$(yabai -m query --windows --window | jq -r '.app // empty'); [ -n "$app" ] && $HOME/.config/yabai/scripts/ignore-list.sh toggle "$app"

# Move/reinsert focused window. Warp un-stacks a single focused window instead of moving the whole stack pane.
cmd + alt - h : if yabai -m window --space prev; then yabai -m space --focus prev; else yabai -m window --space last; yabai -m space --focus last; fi
cmd + alt - l : if yabai -m window --space next; then yabai -m space --focus next; else yabai -m window --space first; yabai -m space --focus first; fi

# Resize focused window/pane.
alt - 0x1B : $HOME/.config/yabai/scripts/resize.sh shrink
alt - 0x18 : $HOME/.config/yabai/scripts/resize.sh grow
alt + shift - 0x1B : $HOME/.config/yabai/scripts/resize.sh shrink 4
alt + shift - 0x18 : $HOME/.config/yabai/scripts/resize.sh grow 4

# Focus/open applications.
cmd + alt + ctrl - s : $HOME/.config/yabai/scripts/focus-app.sh Slack
cmd + alt + ctrl - t : $HOME/.config/yabai/scripts/focus-app.sh Alacritty
cmd + alt + ctrl + shift - t : $HOME/.config/yabai/scripts/focus-app.sh Ghostty
cmd + alt + ctrl - c : $HOME/.config/yabai/scripts/focus-app.sh Codex
cmd + alt + ctrl - b : $HOME/.config/yabai/scripts/focus-app.sh Arc
cmd + alt + ctrl - d : $HOME/.config/yabai/scripts/focus-app.sh Discord
cmd + alt + ctrl - f : $HOME/.config/yabai/scripts/focus-app.sh FindMy
cmd + alt + ctrl - m : $HOME/.config/yabai/scripts/focus-app.sh Messages

# Toggle float modes.
alt + shift - return : $HOME/.config/yabai/scripts/toggle-float.sh center
alt - return : $HOME/.config/yabai/scripts/toggle-float.sh fullscreen

# Switch focused/left-stack window into main, or reset/re-apply display-aware layout.
alt - m : $HOME/.config/yabai/scripts/switch-main.sh
alt - 0 : $HOME/.config/yabai/scripts/apply-layout.sh reset

# Focus spaces by left-to-right display order, then mission-control index.
# Mark before explicit space focus so the yabai hook can skip floating overlays.
alt - 1 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-1
alt - 2 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-2
alt - 3 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-3
alt - 4 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-4
alt - 5 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-5
alt - 6 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-6
alt - 7 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-7
alt - 8 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-8
alt - 9 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-9
ctrl - 1 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-1
ctrl - 2 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-2
ctrl - 3 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-3
ctrl - 4 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-4
ctrl - 5 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-5
ctrl - 6 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-6
ctrl - 7 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-7
ctrl - 8 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-8
ctrl - 9 : $HOME/.config/yabai/scripts/skip-focus.sh mark; yabai -m space --focus space-9

# Move focused window to spaces and follow it.
alt + cmd - 1 : yabai -m window --space space-1 && yabai -m space --focus space-1
alt + cmd - 2 : yabai -m window --space space-2 && yabai -m space --focus space-2
alt + cmd - 3 : yabai -m window --space space-3 && yabai -m space --focus space-3
alt + cmd - 4 : yabai -m window --space space-4 && yabai -m space --focus space-4
alt + cmd - 5 : yabai -m window --space space-5 && yabai -m space --focus space-5
alt + cmd - 6 : yabai -m window --space space-6 && yabai -m space --focus space-6
alt + cmd - 7 : yabai -m window --space space-7 && yabai -m space --focus space-7
alt + cmd - 8 : yabai -m window --space space-8 && yabai -m space --focus space-8
alt + cmd - 9 : yabai -m window --space space-9 && yabai -m space --focus space-9
